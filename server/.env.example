# Server Environment Variables
NODE_ENV=development
PORT=3001
DATABASE_URL=postgresql://fetishapp:fetishapp_dev_password@localhost:5432/fetishapp
JWT_SECRET=change_me_to_a_random_secret_64_chars_minimum
JWT_REFRESH_SECRET=change_me_to_another_random_secret_64_chars
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
CLIENT_URL=http://localhost:5173
